# Force LF line endings for text files across all platforms.
# Prevents Windows checkouts from corrupting CHECKSUMS.txt and breaking
# `sha256sum -c CHECKSUMS.txt` verification documented in docs/RELEASES.md.

* text=auto eol=lf
*.csv text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.sql text eol=lf
CHECKSUMS.txt text eol=lf
